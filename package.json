{
  "name": "DrawHive",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "migrate":"cd packages/db && npx prisma migrate deploy && cd ../..",
    "dev:generate":"cd packages/db && npx prisma generate && cd ../..",
    "start:http":" pnpm run migrate && node apps/http-backend/dist/index.js",
    "start:ws":" pnpm run migrate &&  node apps/ws-backend/dist/index.js",
    "start:fe":" cd apps/frontend && pnpm run start"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
